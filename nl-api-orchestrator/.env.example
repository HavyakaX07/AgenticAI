# LLM Configuration
LLM_PROVIDER=ollama
OPENAI_BASE_URL=http://ollama:11434/v1
OPENAI_API_KEY=dummy
MODEL_NAME=llama3.1:8b

# Embedding Configuration
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_SERVER_URL=http://mcp-embed:9001

# MCP Services
API_TOOLS_URL=http://mcp-api:9000
OPA_URL=http://mcp-policy:8181/v1/data/policy/allow

# Security
ALLOWLIST_PREFIXES=https://api.example.com/,http://mock-api:8888/
API_TOKEN=demo-token

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otelcol:4317
OTEL_SERVICE_NAME=nl-api-orchestrator
LOG_LEVEL=INFO

