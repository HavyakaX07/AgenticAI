{
  "dashboard": {
    "id": null,
    "uid": "nl-api-orchestrator",
    "title": "NL → API Orchestrator Overview",
    "tags": ["orchestrator", "api", "llm"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "type": "graph",
        "title": "Request Rate by Decision",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(orchestrator_requests_total[5m])",
            "legendFormat": "{{decision}} - {{tool}}"
          }
        ]
      },
      {
        "id": 2,
        "type": "graph",
        "title": "Request Duration",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(orchestrator_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.50, rate(orchestrator_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p50"
          }
        ]
      },
      {
        "id": 3,
        "type": "stat",
        "title": "Total Requests",
        "gridPos": {"x": 0, "y": 8, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "sum(orchestrator_requests_total)"
          }
        ]
      },
      {
        "id": 4,
        "type": "stat",
        "title": "Success Rate",
        "gridPos": {"x": 6, "y": 8, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "sum(rate(orchestrator_requests_total{decision=\"USE_TOOL\"}[5m])) / sum(rate(orchestrator_requests_total[5m])) * 100"
          }
        ]
      },
      {
        "id": 5,
        "type": "piechart",
        "title": "Decision Distribution",
        "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum by (decision) (orchestrator_requests_total)",
            "legendFormat": "{{decision}}"
          }
        ]
      },
      {
        "id": 6,
        "type": "graph",
        "title": "LLM Token Usage",
        "gridPos": {"x": 0, "y": 16, "w": 24, "h": 8},
        "targets": [
          {
            "expr": "rate(orchestrator_llm_tokens_total[5m])",
            "legendFormat": "{{type}}"
          }
        ]
      }
    ]
  }
}

