[
  {
    "name": "copy_device_credentials",
    "description": "Copy credentials from one source device to multiple destination devices. Supports copying SNMP read, SNMP write, and CLI credentials selectively. Use when users want to replicate, duplicate, or copy device authentication settings across multiple network devices.",
    "endpoint": "POST /copyDeviceCredentials",
    "auth": "bearer",
    "risk": "low",
    "rbac_required": {
      "navigation": "CREDENTIAL_REPOSITORY",
      "right": "EDIT"
    },
    "validation_layers": [
      "Bean Validation",
      "RBAC Permission Check",
      "Device Area Authorization",
      "Business Logic Validation"
    ],
    "input_schema": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "description": "Source device ID from which credentials will be copied",
          "required": true
        },
        "destinations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "maxItems": 1000,
          "description": "List of destination device IDs to copy credentials to",
          "required": true
        },
        "snmpRead": {
          "type": "boolean",
          "description": "Flag to include SNMP read credentials in copy operation",
          "default": false
        },
        "snmpWrite": {
          "type": "boolean",
          "description": "Flag to include SNMP write credentials in copy operation",
          "default": false
        },
        "cli": {
          "type": "boolean",
          "description": "Flag to include CLI credentials in copy operation",
          "default": false
        },
        "userName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "pattern": "^[a-zA-Z0-9@._-]+$",
          "description": "Username of the logged-in user performing the operation",
          "required": true
        }
      },
      "required": ["source", "destinations", "userName"]
    },
    "response_schema": {
      "success": {
        "status": true,
        "errorCode": "SUCCESS",
        "message": "Credential Copy action success"
      },
      "error": {
        "status": false,
        "errorCode": "COPY_CREDENTIAL_FAILED",
        "message": "Credential Copy action failed"
      }
    },
    "examples": [
      {
        "user": "Copy credentials from device 172.16.122.190 to devices 172.16.122.191 and 172.16.122.192",
        "payload": {
          "source": "device-001",
          "destinations": ["device-002", "device-003"],
          "snmpRead": true,
          "snmpWrite": true,
          "cli": false,
          "userName": "admin"
        }
      },
      {
        "user": "Replicate SNMP settings from main router to backup routers",
        "payload": {
          "source": "router-main-001",
          "destinations": ["router-backup-001", "router-backup-002"],
          "snmpRead": true,
          "snmpWrite": true,
          "cli": false,
          "userName": "networkadmin"
        }
      },
      {
        "user": "Copy all credentials including CLI from device DEV001 to DEV002",
        "payload": {
          "source": "DEV001",
          "destinations": ["DEV002"],
          "snmpRead": true,
          "snmpWrite": true,
          "cli": true,
          "userName": "operator"
        }
      }
    ],
    "error_codes": {
      "INVALID_COPY_CREDENTIAL_FORMAT_DATA": "Invalid format input for copy credentials",
      "COPY_CREDENTIAL_FAILED": "Credential copy operation failed",
      "INVALID_RIGHT": "User does not have required permissions"
    }
  },
