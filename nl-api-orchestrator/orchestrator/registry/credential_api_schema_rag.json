  {
    "name": "set_bulk_device_credentials",
    "description": "Update credentials for multiple devices simultaneously. Supports selective update of SNMP read, SNMP write, and CLI credentials. Use when users want to configure, update, or modify authentication for multiple network devices at once.",
    "endpoint": "POST /setBulkEditOfDeviceCredential",
    "auth": "bearer",
    "risk": "critical",
    "rbac_required": {
      "navigation": "CREDENTIAL_REPOSITORY",
      "right": "EDIT"
    },
    "validation_layers": [
      "Bean Validation",
      "RBAC Permission Check",
      "Device Area Authorization",
      "Bulk Credentials Payload Validation",
      "Business Logic Validation"
    ],
    "input_schema": {
      "type": "object",
      "properties": {
        "deviceId": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 255
          },
          "maxItems": 1000,
          "description": "List of device IDs to update credentials for",
          "required": true
        },
        "credentials": {
          "type": "object",
          "maxProperties": 10,
          "description": "Credential details to be applied to all devices",
          "properties": {
            "snmpRead": {
              "type": "object",
              "description": "SNMP read credential settings"
            },
            "snmpWrite": {
              "type": "object",
              "description": "SNMP write credential settings"
            },
            "cli": {
              "type": "object",
              "description": "CLI credential settings"
            }
          },
          "required": true
        },
        "snmpReadCredChange": {
          "type": "boolean",
          "description": "Flag indicating if SNMP read credentials should be updated",
          "default": false
        },
        "snmpWriteCredChange": {
          "type": "boolean",
          "description": "Flag indicating if SNMP write credentials should be updated",
          "default": false
        },
        "cliCredChange": {
          "type": "boolean",
          "description": "Flag indicating if CLI credentials should be updated",
          "default": false
        }
      },
      "required": ["deviceId", "credentials"]
    },
    "response_schema": {
      "success": {
        "status": true,
        "errorCode": "SUCCESS",
        "message": "set credentials to multiple devices is success"
      },
      "error": {
        "status": false,
        "errorCode": "SET_CREDENTIAL_FAILED",
        "message": "set credentials to multiple devices is failed"
      }
    },
    "examples": [
      {
        "user": "Update SNMP community string for all switches in building A",
        "payload": {
          "deviceId": ["switch-A-001", "switch-A-002", "switch-A-003"],
          "credentials": {
            "snmpRead": {
              "version": 2,
              "port": 161,
              "enc_readCommunity": "encrypted_community_string"
            }
          },
          "snmpReadCredChange": true,
          "snmpWriteCredChange": false,
          "cliCredChange": false
        }
      },
      {
        "user": "Change CLI password for 10 routers in the DMZ zone",
        "payload": {
          "deviceId": ["router-dmz-001", "router-dmz-002", "router-dmz-003"],
          "credentials": {
            "cli": {
              "userId": "admin",
              "enc_password": "encrypted_password",
              "sshPort": 22
            }
          },
          "snmpReadCredChange": false,
          "snmpWriteCredChange": false,
          "cliCredChange": true
        }
      }
    ],
    "error_codes": {
      "INVALID_FORMAT_DATA": "Invalid JSON input",
      "SET_CREDENTIAL_FAILED": "Credential update failed due to validation or execution error",
      "INVALID_RIGHT": "User does not have required permissions"
    }
  },
  {
    "name": "set_device_credentials",
    "description": "Update credentials for a single device. Allows configuration of SNMP read, SNMP write, CLI, and fingerprint details. Use when users want to configure, modify, update, or change authentication settings for one specific network device.",
    "endpoint": "POST /setDeviceCredentials",
    "auth": "bearer",
    "risk": "high",
    "rbac_required": {
      "navigation": "CREDENTIAL_REPOSITORY",
      "right": "EDIT"
    },
    "validation_layers": [
      "Bean Validation",
      "RBAC Permission Check",
      "Device Area Authorization",
      "Device Credential Request Validation",
      "Business Logic Validation"
    ],
    "input_schema": {
      "type": "object",
      "properties": {
        "deviceId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "description": "Unique identifier of the device to update",
          "required": true
        },
        "credentials": {
          "type": "object",
          "description": "Complete credential details for the device",
          "properties": {
            "snmpRead": {
              "type": "object",
              "properties": {
                "version": {
                  "type": "integer",
                  "enum": [1, 2, 3],
                  "description": "SNMP version (1=v1, 2=v2c, 3=v3)"
                },
                "port": {
                  "type": "integer",
                  "default": 161,
                  "description": "SNMP port number"
                },
                "retries": {
                  "type": "integer",
                  "description": "Number of retry attempts"
                },
                "timeout": {
                  "type": "integer",
                  "description": "Timeout in seconds"
                },
                "securityLevel": {
                  "type": "integer",
                  "description": "SNMPv3 security level"
                },
                "userName": {
                  "type": "string",
                  "maxLength": 25,
                  "description": "SNMPv3 username"
                },
                "enc_readCommunity": {
                  "type": "string",
                  "maxLength": 1024,
                  "description": "Encrypted SNMP read community string"
                },
                "authAlgo": {
                  "type": "integer",
                  "description": "Authentication algorithm"
                },
                "enc_authPwd": {
                  "type": "string",
                  "maxLength": 1024,
                  "description": "Encrypted authentication password"
                },
                "encryptAlgo": {
                  "type": "integer",
                  "description": "Encryption algorithm"
                },
                "enc_encryptPwd": {
                  "type": "string",
                  "maxLength": 1024,
                  "description": "Encrypted privacy password"
                },
                "contextEngineId": {
                  "type": "string",
                  "maxLength": 255,
                  "description": "SNMPv3 context engine ID"
                },
                "contextName": {
                  "type": "string",
                  "maxLength": 255,
                  "description": "SNMPv3 context name"
                }
              }
            },
            "snmpWrite": {
              "type": "object",
              "properties": {
                "version": {
                  "type": "integer",
                  "enum": [1, 2, 3]
                },
                "port": {
                  "type": "integer",
                  "default": 161
                },
                "userName": {
                  "type": "string",
                  "maxLength": 25
                },
                "enc_writeCommunity": {
                  "type": "string",
                  "maxLength": 1024,
                  "description": "Encrypted SNMP write community string"
                },
                "authAlgo": {
                  "type": "integer"
                },
                "enc_authPwd": {
                  "type": "string",
                  "maxLength": 1024
                },
                "encryptAlgo": {
                  "type": "integer"
                },
                "enc_encryptPwd": {
                  "type": "string",
                  "maxLength": 1024
                }
              }
            },
            "cli": {
              "type": "object",
              "properties": {
                "userId": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 25,
                  "description": "CLI username",
                  "required": true
                },
                "enc_password": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 1024,
                  "description": "Encrypted CLI password",
                  "required": true
                },
                "sshPort": {
                  "type": "integer",
                  "default": 22,
                  "description": "SSH port number"
                },
                "retryCount": {
                  "type": "integer",
                  "description": "SSH retry count"
                },
                "retryTimeout": {
                  "type": "integer",
                  "default": 30,
                  "description": "SSH retry timeout in seconds"
                },
                "netconfPort": {
                  "type": "integer",
                  "default": 830,
                  "description": "NETCONF port number"
                },
                "netconfRetryCount": {
                  "type": "integer"
                },
                "netconfRetryTimeout": {
                  "type": "integer",
                  "default": 30
                },
                "httpsPort": {
                  "type": "integer",
                  "default": 443,
                  "description": "HTTPS port number"
                },
                "httpsRetryCount": {
                  "type": "integer"
                },
                "httpsRetryTimeout": {
                  "type": "integer",
                  "default": 30
                }
              }
            },
            "fingerPrintDetails": {
              "type": "object",
              "maxProperties": 1,
              "description": "SSH fingerprint details"
            }
          },
          "required": true
        }
      },
      "required": ["deviceId", "credentials"]
    },
    "response_schema": {
      "success": {
        "status": true,
        "errorCode": "SUCCESS",
        "message": "set credentials success"
      },
      "error": {
        "status": false,
        "errorCode": "SET_CREDENTIAL_FAILED",
        "message": "set device credentials failed"
      }
    },
    "examples": [
      {
        "user": "Configure SNMP v3 credentials for device 172.16.122.190",
        "payload": {
          "deviceId": "device-001",
          "credentials": {
            "snmpRead": {
              "version": 3,
              "port": 161,
              "userName": "snmpuser",
              "securityLevel": 3,
              "authAlgo": 1,
              "enc_authPwd": "encrypted_auth_pwd",
              "encryptAlgo": 1,
              "enc_encryptPwd": "encrypted_priv_pwd"
            }
          }
        }
      },
      {
        "user": "Update SSH credentials for router with username admin and port 2222",
        "payload": {
          "deviceId": "router-001",
          "credentials": {
            "cli": {
              "userId": "admin",
              "enc_password": "encrypted_password",
              "sshPort": 2222,
              "retryCount": 3,
              "retryTimeout": 30
            }
          }
        }
      },
      {
        "user": "Set SNMP v2c community string for switch SW-001",
        "payload": {
          "deviceId": "SW-001",
          "credentials": {
            "snmpRead": {
              "version": 2,
              "port": 161,
              "enc_readCommunity": "encrypted_public"
            },
            "snmpWrite": {
              "version": 2,
              "port": 161,
              "enc_writeCommunity": "encrypted_private"
            }
          }
        }
      }
    ],
    "error_codes": {
      "INVALID_FORMAT_DATA": "Invalid JSON input",
      "SET_CREDENTIAL_FAILED": "Credential update failed",
      "INVALID_RIGHT": "User does not have required permissions"
    }
  },
