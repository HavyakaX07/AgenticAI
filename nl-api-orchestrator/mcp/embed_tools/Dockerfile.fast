# =============================================================================
# FAST DOCKERFILE - CPU-only version (much smaller than CUDA)
# Size: ~2GB (vs 4GB+ for CUDA version)
# =============================================================================

# Use Python slim base with CPU-only PyTorch
FROM python:3.10-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python packages with CPU-only PyTorch
RUN pip install --no-cache-dir \
    torch==2.2.0 --index-url https://download.pytorch.org/whl/cpu && \
    pip install --no-cache-dir \
    fastapi==0.109.0 \
    uvicorn[standard]==0.27.0 \
    pydantic==2.5.3 \
    sentence-transformers==2.5.1 \
    faiss-cpu==1.7.4 \
    numpy==1.26.3

# Pre-download model during build (cached in image layer)
ENV TRANSFORMERS_CACHE=/app/model_cache
ENV SENTENCE_TRANSFORMERS_HOME=/app/model_cache
RUN python -c "from sentence_transformers import SentenceTransformer; print('Downloading model...'); SentenceTransformer('BAAI/bge-small-en-v1.5'); print('Model cached!')"


# Copy application code
COPY src/ /app/src/

EXPOSE 9001

HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -f http://localhost:9001/health || exit 1

CMD ["uvicorn", "src.server:app", "--host", "0.0.0.0", "--port", "9001"]

