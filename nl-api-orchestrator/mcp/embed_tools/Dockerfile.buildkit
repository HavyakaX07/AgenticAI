# =============================================================================
# OPTIMIZED FAST BUILD with BuildKit Cache Mounts
# Uses Docker BuildKit features for maximum caching
# =============================================================================
# syntax=docker/dockerfile:1.4

FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN --mount=type=cache,target=/var/cache/apt \
    apt-get update && apt-get install -y \
    curl \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY requirements.poc.txt /app/requirements.txt

# Install Python packages with persistent pip cache
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -r requirements.txt

# Pre-download model with cache mount (shared across builds)
RUN --mount=type=cache,target=/root/.cache/huggingface \
    python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('BAAI/bge-small-en-v1.5')"

# Copy application
COPY src/ /app/src/

EXPOSE 9001

HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -f http://localhost:9001/health || exit 1

CMD ["uvicorn", "src.server:app", "--host", "0.0.0.0", "--port", "9001"]

