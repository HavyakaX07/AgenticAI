# =============================================================================
# ULTRA-MINIMAL DOCKERFILE - Target size: ~800MB-1.2GB
# Most aggressive optimization:
# 1. Alpine Linux base (much smaller than Debian)
# 2. CPU-only PyTorch
# 3. Minimal sentence-transformers
# 4. Strip unnecessary files
# =============================================================================

FROM python:3.10-alpine as builder

WORKDIR /build

# Install build dependencies for compiling Python packages
RUN apk add --no-cache \
    gcc \
    g++ \
    musl-dev \
    linux-headers \
    openblas-dev \
    lapack-dev \
    gfortran \
    freetype-dev \
    libpng-dev

# Install Python packages in a target directory
RUN pip install --no-cache-dir --target=/build/packages \
    fastapi==0.109.0 \
    uvicorn==0.27.0 \
    pydantic==2.5.3 \
    sentence-transformers==2.5.1 \
    faiss-cpu==1.7.4 \
    numpy==1.26.3 \
    torch==2.2.0 --index-url https://download.pytorch.org/whl/cpu

# Pre-download model
ENV TRANSFORMERS_CACHE=/build/model_cache
ENV SENTENCE_TRANSFORMERS_HOME=/build/model_cache
RUN python -c "import sys; sys.path.insert(0, '/build/packages'); \
    from sentence_transformers import SentenceTransformer; \
    SentenceTransformer('BAAI/bge-small-en-v1.5')"

# Clean up unnecessary files to reduce size
RUN find /build/packages -type d -name "tests" -exec rm -rf {} + 2>/dev/null || true
RUN find /build/packages -type d -name "test" -exec rm -rf {} + 2>/dev/null || true
RUN find /build/packages -type f -name "*.pyc" -delete
RUN find /build/packages -type f -name "*.pyo" -delete
RUN find /build/packages -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true

# Runtime stage
FROM python:3.10-alpine

WORKDIR /app

# Install only runtime dependencies
RUN apk add --no-cache \
    openblas \
    lapack \
    libstdc++ \
    libgomp \
    curl

# Copy packages and model from builder
COPY --from=builder /build/packages /usr/local/lib/python3.10/site-packages/
COPY --from=builder /build/model_cache /app/model_cache

ENV TRANSFORMERS_CACHE=/app/model_cache
ENV SENTENCE_TRANSFORMERS_HOME=/app/model_cache

# Copy application code
COPY src/ /app/src/

EXPOSE 9001

HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -f http://localhost:9001/health || exit 1

CMD ["python", "-m", "uvicorn", "src.server:app", "--host", "0.0.0.0", "--port", "9001"]

